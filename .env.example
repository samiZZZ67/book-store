DJANGO_SECRET_KEY=change-this-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
SITE_URL=http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0
MAX_UPLOAD_SIZE=52428800
MAX_THUMBNAIL_SIZE=3145728

# Default is SQLite, which needs no database server.
# Render provides DATABASE_URL automatically when you attach PostgreSQL.
DATABASE_URL=
DB_SSL_REQUIRE=1

# To use PostgreSQL locally without DATABASE_URL, set DB_ENGINE=postgresql.
DB_ENGINE=sqlite
POSTGRES_DB=simple_pdf_site
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Telegram notifications. Add up to two comma-separated admin usernames.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-this-random-secret
TELEGRAM_ADMIN_USERNAMES=adminusername1,adminusername2
MAX_TELEGRAM_ADMINS=2
TELEGRAM_API_TIMEOUT=8
