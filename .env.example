DJANGO_SECRET_KEY=change-this-secret
DJANGO_ENV=development
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
SITE_URL=http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0
# 0, blank, none, or unlimited means no Django-side PDF upload size limit.
MAX_UPLOAD_SIZE=0
MAX_THUMBNAIL_SIZE=12582912
DATA_UPLOAD_MAX_MEMORY_SIZE=
FILE_UPLOAD_MAX_MEMORY_SIZE=0

# Cloudinary media storage. Cloudinary stores uploaded PDFs and thumbnails;
# the SQL database still stores users, books, and access requests.
USE_CLOUDINARY_STORAGE=
CLOUDINARY_URL=
CLOUDINARY_STORAGE_PREFIX=pdf-library
CLOUDINARY_DOWNLOAD_TIMEOUT=20
CLOUDINARY_UPLOAD_CHUNK_SIZE=6291456

# Default is SQLite, which needs no database server.
# Render can provide DATABASE_URL automatically when you attach PostgreSQL.
# Azure can use DATABASE_URL or the AZURE_POSTGRESQL_* variables below.
DATABASE_URL=
DB_SSL_REQUIRE=1

# Azure App Service / Azure PostgreSQL Service Connector values.
AZURE_POSTGRESQL_HOST=
AZURE_POSTGRESQL_NAME=
AZURE_POSTGRESQL_USER=
AZURE_POSTGRESQL_PASSWORD=
AZURE_POSTGRESQL_PORT=5432
AZURE_POSTGRESQL_SSL=true
AZURE_POSTGRESQL_CONNECTIONSTRING=

# To use PostgreSQL locally without DATABASE_URL, set DB_ENGINE=postgresql.
DB_ENGINE=sqlite
POSTGRES_DB=simple_pdf_site
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Telegram notifications. Add up to two comma-separated admin usernames.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-this-random-secret
TELEGRAM_ADMIN_USERNAMES=adminusername1,adminusername2
MAX_TELEGRAM_ADMINS=2
TELEGRAM_API_TIMEOUT=8
